      "issue": "G-Drive API endpoints returning 404",
      "root_cause": "Router had prefix '/api/gdrive' but was included in api_router which already has '/api' prefix, resulting in '/api/api/gdrive/...' endpoints",
      "fix": "Changed router prefix from '/api/gdrive' to '/gdrive' in /app/backend/routers/gdrive.py",
      "file": "/app/backend/routers/gdrive.py"
    },
    {
      "issue": "PDF Invoice download failing with 'TypeError: doc.autoTable is not a function'",
      "root_cause": "jspdf-autotable 5.0+ changed import API - no longer auto-extends jsPDF instance",
      "fix": "Changed import from 'import jsPDF from jspdf; import jspdf-autotable' to 'import { jsPDF } from jspdf; import { autoTable } from jspdf-autotable' and updated autoTable calls to use autoTable(doc, {...}) syntax",
      "file": "/app/frontend/src/services/pdfService.js"
    }
